# Copy to .env and fill in. .env is git-ignored.
# The pipeline runs fully locally with NO key (local sentence-transformers embeddings +
# a deterministic FakeLLM). A key is only needed to (a) generate answers with a hosted
# model and (b) run the LLM-as-judge in `record` mode to produce headline eval numbers.

# --- Generation + judge backend ---
# "auto"     -> OpenAI if OPENAI_API_KEY is set, else the deterministic offline FakeLLM
# "openai"   -> a hosted OpenAI-compatible endpoint (needs OPENAI_API_KEY)
# "local_hf" -> a local transformers model on CPU/GPU (no key; used for the committed numbers)
# "fake"     -> deterministic offline stand-in (tests / key-less dev)
RAG_LLM_BACKEND=auto
RAG_LOCAL_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# --- OpenAI-compatible provider (used when the backend resolves to "openai") ---
OPENAI_API_KEY=
# Override to point at any OpenAI-compatible server (Ollama, vLLM, LM Studio, ...).
OPENAI_BASE_URL=https://api.openai.com/v1
RAG_LLM_MODEL=gpt-4o-mini
RAG_JUDGE_MODEL=gpt-4o-mini

# --- Embeddings ---
# "local"  -> sentence-transformers (default, free, offline)
# "openai" -> hosted embeddings (needs OPENAI_API_KEY)
RAG_EMBEDDING_BACKEND=local
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Cassette mode for reproducible / free evals ---
# "off"    -> always call the live provider
# "record" -> call live provider AND persist responses to evals/fixtures/cassettes.json
# "replay" -> serve responses from cassettes; miss => error (re-record required)
RAG_CASSETTE=off

# --- Retrieval / graph knobs ---
RAG_TOP_K=5
RAG_MAX_REFORMULATIONS=2

# --- Tracing ---
# "console" -> print spans; "none" -> disable; "otlp" -> export to OTEL_EXPORTER_OTLP_ENDPOINT
RAG_TRACING=console
